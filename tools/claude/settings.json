{
  "permissions": {
    "allow": [
      "WebSearch"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "node $HOME/.claude/hud/status.mjs"
  },
  "enabledPlugins": {
    "claude-code-wakatime@wakatime": true
  },
  "promptSuggestionEnabled": false,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true
}
